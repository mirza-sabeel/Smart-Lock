  Serial.begin(9600);
  pinMode(5, OUTPUT);
  pinMode(4, OUTPUT);
  mqtt.subscribe(&rx);
}

void loop(){
  WiFi.begin("doorlock","password");
  MQTT_connect();
  tx.publish(analogRead(A0));
    Adafruit_MQTT_Subscribe *subscription;
  while ((subscription = mqtt.readSubscription(5000))) {
  if (subscription ==&rx) {
    item = (char *)rx.lastread;
    Serial.println(item);
    if (item == "1") {
      Serial.println("on");
      digitalWrite(5,HIGH); 
     
    } else if (item == "0") {
      Serial.println("off");
      digitalWrite(5,LOW);
    }

  }
  }

