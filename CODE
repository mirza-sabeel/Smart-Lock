void MQTT_connect();
Adafruit_MQTT_Client mqtt(&client, "broker.emqx.io", 1883, "", "");
Adafruit_MQTT_Publish tx = Adafruit_MQTT_Publish(&mqtt, "tx");
Adafruit_MQTT_Subscribe rx = Adafruit_MQTT_Subscribe(&mqtt,"loadserver/relayctrl");
void MQTT_connect() {
  int8_t ret;
  if (mqtt.connected()) {
  return;
  }
  Serial.print("Connecting to MQTT... ");
  uint8_t retries = 3;
while ((ret = mqtt.connect()) != 0) {
  Serial.println(mqtt.connectErrorString(ret));
  Serial.println("Retrying MQTT connection in 5 seconds...");
  mqtt.disconnect();
  delay(5000);
  retries--;
if (retries == 0) {
 while (1);
  }
}
  Serial.println("MQTT Connected!");
}

